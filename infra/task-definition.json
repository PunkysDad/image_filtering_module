{
  "family": "picmagiq",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "3072",
  "executionRoleArn": "arn:aws:iam::565122144780:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::565122144780:role/ecsTaskExecutionRole",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "containerDefinitions": [
    {
      "name": "picmagiq",
      "image": "565122144780.dkr.ecr.us-east-1.amazonaws.com/picmagiq:latest",
      "essential": true,
      "portMappings": [
        {
          "name": "http",
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PLAYWRIGHT_BROWSERS_PATH", "value": "/ms-playwright" },
        { "name": "NEXT_TELEMETRY_DISABLED", "value": "1" }
      ],
      "secrets": [
        { "name": "NEXT_PUBLIC_SUPABASE_URL", "valueFrom": "arn:aws:ssm:us-east-1:565122144780:parameter/picmagiq/NEXT_PUBLIC_SUPABASE_URL" },
        { "name": "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY", "valueFrom": "arn:aws:ssm:us-east-1:565122144780:parameter/picmagiq/NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY" },
        { "name": "SUPABASE_SECRET_KEY", "valueFrom": "arn:aws:ssm:us-east-1:565122144780:parameter/picmagiq/SUPABASE_SECRET_KEY" },
        { "name": "ANTHROPIC_API_KEY", "valueFrom": "arn:aws:ssm:us-east-1:565122144780:parameter/picmagiq/ANTHROPIC_API_KEY" },
        { "name": "STRIPE_SECRET_KEY", "valueFrom": "arn:aws:ssm:us-east-1:565122144780:parameter/picmagiq/STRIPE_SECRET_KEY" },
        { "name": "STRIPE_WEBHOOK_SECRET", "valueFrom": "arn:aws:ssm:us-east-1:565122144780:parameter/picmagiq/STRIPE_WEBHOOK_SECRET" },
        { "name": "STRIPE_BASIC_PRICE_ID", "valueFrom": "arn:aws:ssm:us-east-1:565122144780:parameter/picmagiq/STRIPE_BASIC_PRICE_ID" },
        { "name": "STRIPE_PREMIUM_PRICE_ID", "valueFrom": "arn:aws:ssm:us-east-1:565122144780:parameter/picmagiq/STRIPE_PREMIUM_PRICE_ID" },
        { "name": "NEXT_PUBLIC_STRIPE_BASIC_PRICE_ID", "valueFrom": "arn:aws:ssm:us-east-1:565122144780:parameter/picmagiq/NEXT_PUBLIC_STRIPE_BASIC_PRICE_ID" },
        { "name": "NEXT_PUBLIC_STRIPE_PREMIUM_PRICE_ID", "valueFrom": "arn:aws:ssm:us-east-1:565122144780:parameter/picmagiq/NEXT_PUBLIC_STRIPE_PREMIUM_PRICE_ID" },
        { "name": "NEXT_PUBLIC_APP_URL", "valueFrom": "arn:aws:ssm:us-east-1:565122144780:parameter/picmagiq/NEXT_PUBLIC_APP_URL" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/picmagiq",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
